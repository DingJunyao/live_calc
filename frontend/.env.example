VITE_API_URL=/api/v1
VITE_ALLOWED_HOSTS=example,localhost,127.0.0.1,::1

# 开发服务器端口与后端地址（vite.config.ts 读取，自定义端口时改这里）
VITE_DEV_PORT=5173
VITE_DEV_BACKEND_URL=http://localhost:8000

# 数据仓库图片回退地址（当本地图片不存在时使用远程地址）
VITE_DATA_REPO_IMAGE_BASE=https://raw.githubusercontent.com/DingJunyao/HowToCook_json/corr/out

# 请求超时配置（毫秒）
VITE_REQUEST_TIMEOUT=10000       # 默认请求超时
VITE_LONG_REQUEST_TIMEOUT=30000  # 长任务请求超时（成本计算、全部历史等）

# === Docker 部署相关（仅生产容器用，本地开发忽略）===
# 前端容器内 nginx 反代的后端地址。
# - 分开部署（docker-compose.split.yml）：默认 http://backend:8000（compose 服务名）
# - 统一部署（all-in-one）：默认 http://127.0.0.1:8000（同容器 uvicorn）
# - 脱 compose 裸部署：改成后端实际地址，如 http://10.0.0.5:8000
# 部署时 cp frontend/.env.example frontend/.env 后按需修改，并挂载到容器 /app/.env
BACKEND_URL=http://backend:8000
